<article class="doku-document-container clearfix">
    <header class="hero is-light" id="doku-document-hero">
        <div class="hero-body">
            <h1 class="title">文章归档</h1>
        </div>
    </header>
    <div class="columns">
        <div class="column doku-document-wrapper">
            <div class="content">
                <% if (page.posts && page.posts.length > 0) { %>
                    <% page.posts.each(function(post) { %>
                    <div class="archive-item">
                        <h3><a href="<%= url_for(post.path) %>"><%= post.title %></a></h3>
                        <p class="archive-date"><%= date(post.date, 'YYYY-MM-DD') %></p>
                        <p class="archive-excerpt"><%= post.excerpt || post.content.substring(0, 100) %>...</p>
                    </div>
                    <% }) %>
                <% } else { %>
                    <p>暂无文章</p>
                <% } %>
            </div>
        </div>
    </div>
</article>