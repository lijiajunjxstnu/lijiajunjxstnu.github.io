<% const sidebar = theme.sidebar[page.lang] && theme.sidebar[page.lang][page.type] ? theme.sidebar[page.lang][page.type] : (theme.sidebar[page.lang] && theme.sidebar[page.lang]['docs'] ? theme.sidebar[page.lang]['docs'] : null); %>
<% const navbar = theme.navbar.links[page.lang]; %>

<aside class="doku-sidebar" id="doku-sidebar">
    <div class="doku-sidebar-content">
        <div class="menu">
            <% if (theme.navbar.links) { %>
                <ul class="menu-list is-hidden-desktop">
                    <% for (const link of navbar) { %>
                        <% if (link.text) { %>
                            <li><a href="<%= url_for(link.url) %>"><%= link.text %></span></a></li>
                        <% } %>
                    <% } %>
                </ul>
            <% } %>
            <hr class="is-hidden-desktop">
            <% if (sidebar && sidebar.items) { %>
                <% if (sidebar.level === 1) { %>
                    <ul class="menu-list">
                        <% for (const item of sidebar.items) { %>
                            <% const itemTitle = item.split(' | ')[0]; const itemPath = item.split(' | ')[1]; %>
                            <li><a <% if (url_for(itemPath) === url_for(page.path) && itemTitle === page.title) { %>class="is-current"<% } %> href="<%= url_for(itemPath) %>"><%= itemTitle %></a></li>
                        <% } %>
                    </ul>
                <% } else if (sidebar.level === 2) { %>
                    <% for (const [header, children] of Object.entries(sidebar.items)) { %>
                        <p class="menu-label"><%= header %></p>
                        <ul class="menu-list">
                            <% for (const item of children) { %>
                                <% const itemTitle = item.split(' | ')[0]; const itemPath = item.split(' | ')[1]; %>
                                <li><a <% if (url_for(itemPath) === url_for(page.path) && itemTitle === page.title) { %>class="is-current"<% } %> href="<%= url_for(itemPath) %>"><%= itemTitle %></a></li>
                            <% } %>
                        </ul>
                    <% } %>
                <% } %>
            <% } %>
        </div>
    </div>
</aside>
